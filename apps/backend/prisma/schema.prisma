// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id              String  @id // Např. "landmarks", "cafes"
  name            String  @unique
  icon            String? // Např. "🏰"
  description     String? // Např. "Historical gems of Pilsen"
  number_of_items Int     @default(0)
  places          Place[]
}

model Place {
  id              String   @id @default(cuid())
  googleId        String   @unique
  name            String
  address         String?
  latitude        Float
  longitude       Float
  photoReference  String?
  description     String?
  
  // Statistiky swipování
  likesCount      Int      @default(0)
  dislikesCount   Int      @default(0)

  // Relace na kategorii
  categoryId      String?   // Cizí klíč (ID kategorie)
  category        Category? @relation(fields: [categoryId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Leaderboard {
  id        String   @id @default(cuid())
  name      String
  score     Int
  createdAt DateTime @default(now())
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String // Hashed password
}

model SwipeSession {
  id                String   @id // sessionId z frontendu (UUID)
  likedLocations    String[] // Pole Google ID
  dislikedLocations String[] // Pole Google ID
  createdAt         DateTime @default(now())
}
