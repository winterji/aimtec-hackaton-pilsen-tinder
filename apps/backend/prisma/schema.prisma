// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id     String  @id @default(cuid())
  name   String  @unique // Např. "kavárna", "park", "památka"
  places Place[] // Pole míst, která do této kategorie patří
}

model Place {
  id              String   @id @default(cuid())
  googleId        String   @unique
  name            String
  address         String?
  latitude        Float
  longitude       Float
  photoReference  String?
  description     String?
  
  // Relace na kategorii
  categoryId      String?   // Cizí klíč (ID kategorie)
  category        Category? @relation(fields: [categoryId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String // Hashed password
}
